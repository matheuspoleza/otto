# Anthropic API key for LLM enrichment (subtitle, actionable items, contextual copy).
# Without this, PR Lens still works — pillars + risk score are deterministic — but
# the sidebar's actionable items and contextual narrative will be empty.
ANTHROPIC_API_KEY=

# Optional: GitHub token to lift the public API rate limit from 60 to 5000 req/h.
# `gh auth token` works if you have the GitHub CLI installed.
GITHUB_TOKEN=
